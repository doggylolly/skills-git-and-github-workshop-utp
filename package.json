{
  "name": "git-github-workshop-utp",
  "version": "1.0.0",
  "description": "Taller de Git y GitHub - Universidad Tecnológica de Panamá",
  "scripts": {
    "start": "npm-run-all -p dev:*",
    "build": "run-s build:11ty build:css",
    "dev:11ty": "eleventy --serve",
    "dev:css": "tailwindcss -i assets/css/tailwind.css -o _site/assets/css/tailwind.css --watch --postcss",
    "build:11ty": "eleventy",
    "build:css": "tailwindcss -i assets/css/tailwind.css -o _site/assets/css/tailwind.css --postcss",
    "build-ghpages": "npx @11ty/eleventy --pathprefix=/Git-GitHub-Workshop-UTP/ && tailwindcss -i assets/css/tailwind.css -o _site/assets/css/tailwind.css --postcss"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@11ty/eleventy": "^3.0.0"
  },
  "devDependencies": {
    "@11ty/eleventy-plugin-bundle": "^3.0.6",
    "autoprefixer": "^10.4.21",
    "gray-matter": "^4.0.3",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.4.17"
  }
}
